{
  "_readme": "Single configuration file. Topics, sources, social settings, podcast shows — everything lives here.",
  "_fetch_priority": "Google News RSS and ESPN JSON API are the primary structured sources. TMDB for entertainment. Web search is last resort only.",

  "topics": {

    "MMA": {
      "category": "SPRT",
      "mode": "active",
      "points_of_interest": [
        "fighter withdraws or is replaced on a card",
        "missed weight or weigh-in incident",
        "title fight announced or cancelled",
        "post-fight decision changed or overturned",
        "suspension handed down in any promotion (UFC, ONE, boxing)",
        "major fight result in any combat sport (UFC, boxing, BJJ superfight)"
      ],
      "search_terms": ["UFC", "MMA", "boxing", "BJJ", "ONE Championship"],
      "rss": [
        "https://news.google.com/rss/search?q=UFC+OR+MMA+OR+boxing+OR+BJJ+when:1d&hl=en-US&gl=US&ceid=US:en",
        "https://www.espn.com/espn/rss/mma/news"
      ],
      "scores": true,
      "scores_url": "https://site.api.espn.com/apis/site/v2/sports/mma/ufc/scoreboard",
      "news_url": "https://now.core.api.espn.com/v1/sports/news?sport=mma&league=ufc&limit=10"
